# Redmine Configuration
REDMINE_URL=https://your-redmine-server.com
REDMINE_API_KEY=your_fallback_api_key_here

# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here

# Web App Dashboard Configuration (for Telegram Web App)
# ⚠️ ВАЖНО: Telegram требует HTTPS для Web App!
# Для production: укажите ваш домен (например: https://yourdomain.com)
# Для локальной разработки: используйте ngrok (https://xxxx.ngrok-free.app)
# Инструкция по настройке ngrok: см. SETUP_NGROK_NOW.md
WEBAPP_URL=https://your-ngrok-url.ngrok-free.app

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/redmine_bot

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Logging Configuration
# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# JSON формат логов (для production и систем агрегации логов)
LOG_JSON=false

# Цветной вывод в консоли (только для разработки)
LOG_COLORED=true
